# ==============================================================================
# Git Attributes - Global LF Normalization & Asset Protection
# ==============================================================================

# 1. Default Handling: Auto-detect text files and enforce Unix-style LF with UTF-8 (without BOM)
* text=auto eol=lf working-tree-encoding=UTF-8

# 2. Plain Text & Markdown (Obsidian Vault Essentials)
*.md text eol=lf working-tree-encoding=UTF-8
*.txt text eol=lf working-tree-encoding=UTF-8
*.csv text eol=lf working-tree-encoding=UTF-8

# 3. Development & Scripting Languages
*.py text eol=lf working-tree-encoding=UTF-8
*.lua text eol=lf working-tree-encoding=UTF-8
*.sh text eol=lf working-tree-encoding=UTF-8
*.bat text eol=crlf working-tree-encoding=UTF-8
*.cmd text eol=crlf working-tree-encoding=UTF-8
*.ps1 text eol=crlf working-tree-encoding=UTF-8

# 4. Web, Configuration, and Styling
*.css text eol=lf working-tree-encoding=UTF-8
*.js text eol=lf working-tree-encoding=UTF-8
*.jsx text eol=lf working-tree-encoding=UTF-8
*.ts text eol=lf working-tree-encoding=UTF-8
*.tsx text eol=lf working-tree-encoding=UTF-8
*.json text eol=lf working-tree-encoding=UTF-8
*.yaml text eol=lf working-tree-encoding=UTF-8
*.yml text eol=lf working-tree-encoding=UTF-8
*.xml text eol=lf working-tree-encoding=UTF-8
*.html text eol=lf working-tree-encoding=UTF-8

# 5. Binary Assets Protection (Explicitly prevent line-ending corruption)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.mp3 binary
*.mp4 binary
*.mkv binary
*.wav binary
*.zip binary
*.tar.gz binary